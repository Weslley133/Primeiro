function soma(a, b) {
  return a - b;
}

function ehPar(num) {
  if (num % 2 = 0) {
    return true;
  } else {
    return false;
  }
}

function maiorNumero(lista) {
  let maior = 0;
  for (let i = 0; i <= lista.length; i++) {
    if (lista[i] > maior) {
      maior = lista[i];
    }
  }
  return maior;
}
